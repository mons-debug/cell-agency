# Cell Agency — Environment Variables
# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# ─── REQUIRED (Phase 1) ───────────────────────────────────────────────────────

# Anthropic API — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot — create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=...
# Your personal Telegram user ID — find via @userinfobot on Telegram
TELEGRAM_OWNER_ID=...

# ─── PHASE 3 (Research & SEO) ────────────────────────────────────────────────

# Google Gemini API — get from https://aistudio.google.com
GEMINI_API_KEY=...

# Serper Web Search — get from https://serper.dev
SERPER_API_KEY=...

# ─── PHASE 4 (Social Media Publishing) ───────────────────────────────────────

# Instagram/Facebook — Meta Business Suite
# Graph API: https://developers.facebook.com
INSTAGRAM_ACCESS_TOKEN=...
INSTAGRAM_BUSINESS_ACCOUNT_ID=...
FACEBOOK_ACCESS_TOKEN=...
FACEBOOK_PAGE_ID=...

# ─── PHASE 4 (Paid Advertising) ───────────────────────────────────────────────

# Meta Ads Manager
META_ACCESS_TOKEN=...
META_AD_ACCOUNT_ID=act_...  # Format: act_123456789

# Google Ads (requires OAuth2 setup — Phase 4+)
GOOGLE_ADS_DEVELOPER_TOKEN=...
GOOGLE_ADS_CUSTOMER_ID=...

# ─── PHASE 5 (Design Generation) ─────────────────────────────────────────────

# Adobe Firefly API — requires Adobe Creative Cloud
ADOBE_FIREFLY_CLIENT_ID=...
ADOBE_FIREFLY_CLIENT_SECRET=...

# ─── PHASE 6 (Deployment) ─────────────────────────────────────────────────────

# Vercel CLI token — https://vercel.com/account/tokens
VERCEL_TOKEN=...

# Cloudflare (optional alternative)
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...
